{
  "schemaVersion": 1,
  "model": {
    "name": "ChessboardFenTensorflowJs frozen chess-piece classifier",
    "version": "v1.0.0",
    "upstreamRepository": "https://github.com/Elucidation/ChessboardFenTensorflowJs",
    "upstreamRevision": "c75063981c4f781f63ac90c0c026402e23ebbef6",
    "license": "MIT"
  },
  "runtime": {
    "name": "TensorFlow.js",
    "version": "4.22.0",
    "license": "Apache-2.0",
    "distribution": "Vendored browser runtime required by loadGraphModel"
  },
  "contract": {
    "alignedBoard": {
      "width": 256,
      "height": 256,
      "channels": 1
    },
    "input": {
      "name": "Input",
      "shape": [
        64,
        1024
      ],
      "dtype": "float32",
      "pixelRange": [
        0,
        255
      ],
      "normalization": "none",
      "tileOrder": "file-major: a8..a1, b8..b1, through h8..h1"
    },
    "keepProbability": {
      "name": "KeepProb",
      "value": 1
    },
    "outputs": {
      "probabilities": {
        "name": "probabilities",
        "shape": [
          64,
          13
        ],
        "semantics": "softmax model scores"
      },
      "prediction": {
        "name": "prediction",
        "shape": [
          64
        ],
        "semantics": "argmax class indices"
      }
    },
    "classes": [
      "empty",
      "white-king",
      "white-queen",
      "white-rook",
      "white-bishop",
      "white-knight",
      "white-pawn",
      "black-king",
      "black-queen",
      "black-rook",
      "black-bishop",
      "black-knight",
      "black-pawn"
    ],
    "upstreamPreprocessing": "Resize the aligned board to 256x256, read the first pixel channel as float32 values in the 0-255 range, slice eight 256x32 files, reshape each to 8x1024, and concatenate to 64x1024. No normalization is applied."
  },
  "assets": [
    {
      "path": "public/tf.min.js",
      "bytes": 1469843,
      "sha256": "300dfae273d20b4046f46a06d735688f03675a807561e9bcb5f664eb2f3d2831"
    },
    {
      "path": "public/models/chess-ocr/model.json",
      "bytes": 38293,
      "sha256": "3fd040ae63e21551d5c484a2b15727e7ff5b4c13b2ee64d33149174d45541053"
    },
    {
      "path": "public/models/chess-ocr/group1-shard1of1.bin",
      "bytes": 3637488,
      "sha256": "ffecdf69a0f8810ee884a4e90a0edfd4ec1f795532987537c269b85e0727e9e2"
    }
  ]
}
