{
  "schemaVersion": 1,
  "model": {
    "name": "ChessboardFenTensorflowJs frozen chess-piece classifier",
    "version": "v1.0.0",
    "upstreamRepository": "https://github.com/Elucidation/ChessboardFenTensorflowJs",
    "upstreamRevision": "c75063981c4f781f63ac90c0c026402e23ebbef6",
    "license": "MIT"
  },
  "runtime": {
    "name": "TensorFlow.js",
    "version": "0.15.3",
    "license": "Apache-2.0",
    "distribution": "Vendored browser runtime required by loadFrozenModel"
  },
  "contract": {
    "alignedBoard": {
      "width": 256,
      "height": 256,
      "channels": 1
    },
    "input": {
      "name": "Input",
      "shape": [64, 1024],
      "dtype": "float32",
      "pixelRange": [0, 255],
      "normalization": "none",
      "tileOrder": "file-major: a8..a1, b8..b1, through h8..h1"
    },
    "keepProbability": {
      "name": "KeepProb",
      "value": 1
    },
    "outputs": {
      "probabilities": {
        "name": "probabilities",
        "shape": [64, 13],
        "semantics": "softmax model scores"
      },
      "prediction": {
        "name": "prediction",
        "shape": [64],
        "semantics": "argmax class indices"
      }
    },
    "classes": [
      "empty",
      "white-king",
      "white-queen",
      "white-rook",
      "white-bishop",
      "white-knight",
      "white-pawn",
      "black-king",
      "black-queen",
      "black-rook",
      "black-bishop",
      "black-knight",
      "black-pawn"
    ],
    "upstreamPreprocessing": "Resize the aligned board to 256x256, read the first pixel channel as float32 values in the 0-255 range, slice eight 256x32 files, reshape each to 8x1024, and concatenate to 64x1024. No normalization is applied."
  },
