{
  "name": "chess-studio-local",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "postinstall": "node scripts/prepare-engine.mjs",
    "build:ocr-core": "node scripts/build-ocr-core.mjs",
    "check:ocr-core": "node scripts/build-ocr-core.mjs --check",
    "dev": "npm run build:ocr-core && vite --host 127.0.0.1",
    "build": "npm run build:ocr-core && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "serve": "node scripts/serve-dist.mjs",
    "test": "npm run check:ocr-core && vitest run && npm run test:install && npm run test:benchmark && npm run test:service-worker && npm run test:code-splitting && npm run test:e2e-runner",
    "test:install": "node --test scripts/verify-ocr-assets.test.mjs",
    "test:benchmark": "node --test scripts/ocr-benchmark.test.mjs",
    "test:service-worker": "node --test scripts/service-worker.test.mjs",
    "test:code-splitting": "node --test scripts/code-splitting.test.mjs",
    "test:e2e-runner": "node --test scripts/run-e2e.test.mjs",
    "benchmark:ocr": "npm run build:ocr-core && node scripts/benchmark-ocr.mjs",
    "benchmark:ocr:release": "npm run build:ocr-core && node scripts/benchmark-ocr.mjs --release",
    "mine:hard-negatives": "node scripts/mine-hard-negatives.mjs",
    "add-baseline-summary": "node scripts/add-baseline-summary.mjs",
    "verify:ocr-assets": "node scripts/verify-ocr-assets.mjs",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:install": "npx playwright install chromium",
    "smoke:engine": "node scripts/smoke-engine.mjs"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "chess.js": "1.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stockfish": "18.0.8"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "pngjs": "^7.0.0",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.0"
  }
}
